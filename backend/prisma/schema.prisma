generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Enums
// ============================================

enum Role {
  ADMIN
  LECTURER
  STUDENT
}

enum SemesterStatus {
  INACTIVE
  ACTIVE
  CLOSED
}

enum EnrollmentStatus {
  AVAILABLE
  ASSIGNED
  COMPLETED
  FAILED
}

enum TopicStatus {
  OPEN
  CLOSED
  FULL
}

enum ThesisStatus {
  IN_PROGRESS
  SUBMITTED
  APPROVED
  UNDER_REVIEW
  REVIEWED
}

enum DocumentType {
  REGISTRATION
  CONFIRMATION
  THESIS_REPORT
}

enum DocumentStatus {
  PENDING
  LECTURER_APPROVED
  LECTURER_REJECTED
  ADMIN_APPROVED
  ADMIN_REJECTED
}

// ============================================
// Models
// ============================================

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         Role
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  refreshToken String?  @map("refresh_token") @db.Text

  lecturer Lecturer?
  student  Student?

  // Documents reviewed by this user (as admin)
  adminReviewedDocuments Document[] @relation("AdminReviewer")

  // Notifications
  notifications Notification[]

  @@map("users")
}

model Semester {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String         @unique
  name      String
  startDate DateTime       @map("start_date") @db.Date
  endDate   DateTime       @map("end_date") @db.Date
  status    SemesterStatus @default(INACTIVE)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  enrollments Enrollment[]
  topics      Topic[]
  lecturerSemesters LecturerSemester[]

  @@map("semesters")
}

model Lecturer {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String  @unique @map("user_id") @db.Uuid
  lecturerId  String  @unique @map("lecturer_id")
  fullName    String  @map("full_name")
  email       String  @unique
  title       String?
  maxStudents Int     @default(5) @map("max_students")

  user User @relation(fields: [userId], references: [id])

  topics                    Topic[]
  reviewedTheses            Thesis[]       @relation("Reviewer")
  thesisReviews             ThesisReview[]
  lecturerReviewedDocuments Document[]     @relation("LecturerReviewer")
  lecturerSemesters         LecturerSemester[]

  @@map("lecturers")
}

model LecturerSemester {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lecturerId  String @map("lecturer_id") @db.Uuid
  semesterId  String @map("semester_id") @db.Uuid
  maxStudents Int @default(5) @map("max_students")

  lecturer Lecturer @relation(fields: [lecturerId], references: [id])
  semester Semester @relation(fields: [semesterId], references: [id])

  @@unique([lecturerId, semesterId])
  @@map("lecturer_semesters")
}

model Student {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String? @unique @map("user_id") @db.Uuid
  studentId String  @unique @map("student_id")
  fullName  String  @map("full_name")
  email     String  @unique

  user User? @relation(fields: [userId], references: [id])

  enrollments Enrollment[]

  @@map("students")
}

model Enrollment {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId  String           @map("student_id") @db.Uuid
  semesterId String           @map("semester_id") @db.Uuid
  status     EnrollmentStatus @default(AVAILABLE)

  student  Student  @relation(fields: [studentId], references: [id])
  semester Semester @relation(fields: [semesterId], references: [id])

  thesis Thesis?

  @@unique([studentId, semesterId])
  @@map("enrollments")
}

model Topic {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  semesterId   String      @map("semester_id") @db.Uuid
  lecturerId   String      @map("lecturer_id") @db.Uuid
  title        String
  description  String?     @db.Text
  requirements String?     @db.Text
  note         String?     @db.Text
  status       TopicStatus @default(OPEN)
  createdAt    DateTime    @default(now()) @map("created_at")

  semester Semester @relation(fields: [semesterId], references: [id])
  lecturer Lecturer @relation(fields: [lecturerId], references: [id])

  theses Thesis[]

  @@map("topics")
}

model Thesis {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enrollmentId String       @unique @map("enrollment_id") @db.Uuid
  topicId      String       @map("topic_id") @db.Uuid
  reviewerId   String?      @map("reviewer_id") @db.Uuid
  title        String
  description  String?      @db.Text
  status       ThesisStatus @default(IN_PROGRESS)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])
  topic      Topic      @relation(fields: [topicId], references: [id])
  reviewer   Lecturer?  @relation("Reviewer", fields: [reviewerId], references: [id])

  documents    Document[]
  thesisReview ThesisReview?

  @@map("theses")
}

model Document {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  thesisId           String         @map("thesis_id") @db.Uuid
  docType            DocumentType   @map("doc_type")
  originalName       String         @map("original_name")
  s3Key              String         @map("s3_key")
  mimeType           String         @map("mime_type")
  fileSize           Int            @map("file_size")
  version            Int            @default(1)
  status             DocumentStatus @default(PENDING)
  lecturerFeedback   String?        @map("lecturer_feedback") @db.Text
  lecturerReviewedBy String?        @map("lecturer_reviewed_by") @db.Uuid
  lecturerReviewedAt DateTime?      @map("lecturer_reviewed_at")
  adminFeedback      String?        @map("admin_feedback") @db.Text
  adminReviewedBy    String?        @map("admin_reviewed_by") @db.Uuid
  adminReviewedAt    DateTime?      @map("admin_reviewed_at")
  createdAt          DateTime       @default(now()) @map("created_at")

  thesis           Thesis    @relation(fields: [thesisId], references: [id])
  lecturerReviewer Lecturer? @relation("LecturerReviewer", fields: [lecturerReviewedBy], references: [id])
  adminReviewer    User?     @relation("AdminReviewer", fields: [adminReviewedBy], references: [id])

  @@map("documents")
}

model ThesisReview {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  thesisId   String   @unique @map("thesis_id") @db.Uuid
  reviewerId String   @map("reviewer_id") @db.Uuid
  score      Decimal  @db.Decimal(4, 2)
  comment    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  thesis   Thesis   @relation(fields: [thesisId], references: [id])
  reviewer Lecturer @relation(fields: [reviewerId], references: [id])

  @@map("thesis_reviews")
}

model Notification {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  type        String
  title       String
  message     String   @db.Text
  isRead      Boolean  @default(false) @map("is_read")
  relatedId   String?  @map("related_id") @db.Uuid
  relatedType String?  @map("related_type")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}
